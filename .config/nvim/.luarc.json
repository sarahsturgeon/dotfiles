{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "LuaJIT",
  "hint.enable": false,
  "workspace.library": ["/Users/sarah/Code/utils/glua-api-snippets"],
  "runtime.plugin": ["/Users/sarah/Code/utils/luals_gmod_include/plugin.lua"],
  "runtime.special": {
    "include": "require",
    "includeCS": "require"
  },
  "format.defaultConfig": {
    "indent_style": "space",
    "indent_size": "4",
    "tab_width": "4",
    "quote_style": "double",
    "max_line_length": "120",
    "end_of_line": "unset",
    "insert_final_newline": "false",
    "space_before_inline_comment": "1",
    "space_around_table_append_operator": "true",
    "space_before_function_call_single_arg": "none",
    "space_inside_function_call_parentheses": "true",
    "space_inside_function_param_list_parentheses": "true"
  }
}
